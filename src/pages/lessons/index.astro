---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Lessons: FTCPA">
  <div class="lessons-hero">
    <h1>Lessons</h1>
    <p class="hero-sub">Work through these guides in order or jump to the section you need. Each lesson is self-contained.</p>
  </div>

  <div class="lessons-list">

    <!-- Section 1: Getting Started -->
    <div class="section-group">
      <h2 class="section-label"><i class="fa-solid fa-flag-checkered"></i> Getting Started</h2>
      <div class="section-lessons">
        <a href="/lessons/lesson-0/" class="lesson-card">
          <div class="lesson-icon"><i class="fa-solid fa-compass"></i></div>
          <div class="lesson-body">
            <h3>How to Use This Tutorial</h3>
            <p>Navigation, accessibility features, and what to expect from each lesson.</p>
          </div>
          <i class="fa-solid fa-chevron-right card-arrow"></i>
        </a>
      </div>
    </div>

    <!-- Section 2: Good Practices & Requirements -->
    <div class="section-group">
      <h2 class="section-label"><i class="fa-solid fa-clipboard-check"></i> Practices & Requirements</h2>
      <div class="section-lessons">
        <a href="/lessons/lesson-1/" class="lesson-card">
          <div class="lesson-icon"><i class="fa-solid fa-list-check"></i></div>
          <div class="lesson-body">
            <h3>General Requirements</h3>
            <p>Page limits, formatting rules, and the baseline your portfolio must meet.</p>
          </div>
          <i class="fa-solid fa-chevron-right card-arrow"></i>
        </a>
        <a href="/lessons/lesson-2/" class="lesson-card">
          <div class="lesson-icon"><i class="fa-solid fa-star"></i></div>
          <div class="lesson-body">
            <h3>Best Practices</h3>
            <p>Layout tips, visual hierarchy, and writing strategies that impress judges.</p>
          </div>
          <i class="fa-solid fa-chevron-right card-arrow"></i>
        </a>
      </div>
    </div>

    <!-- Section 3: Portfolio Pages -->
    <div class="section-group">
      <h2 class="section-label"><i class="fa-solid fa-book-open"></i> Portfolio Pages</h2>
      <div class="section-lessons">
        <a href="/lessons/lesson-4/" class="lesson-card">
          <div class="lesson-icon"><i class="fa-solid fa-users"></i></div>
          <div class="lesson-body">
            <h3>Team Overview</h3>
            <p>Introduce your team, roles, and what makes your group unique.</p>
          </div>
          <i class="fa-solid fa-chevron-right card-arrow"></i>
        </a>
        <a href="/lessons/lesson-3/" class="lesson-card">
          <div class="lesson-icon"><i class="fa-solid fa-pen-ruler"></i></div>
          <div class="lesson-body">
            <h3>Design Process</h3>
            <p>Show your engineering journey: brainstorming, prototyping, and iteration.</p>
          </div>
          <i class="fa-solid fa-chevron-right card-arrow"></i>
        </a>
        <a href="/lessons/lesson-5/" class="lesson-card">
          <div class="lesson-icon"><i class="fa-solid fa-drafting-compass"></i></div>
          <div class="lesson-body">
            <h3>CAD & Technical Drawings</h3>
            <p>Present 3D models, dimensioned drawings, and technical specifications.</p>
          </div>
          <i class="fa-solid fa-chevron-right card-arrow"></i>
        </a>
        <a href="/lessons/lesson-6/" class="lesson-card">
          <div class="lesson-icon"><i class="fa-solid fa-gears"></i></div>
          <div class="lesson-body">
            <h3>Robot Subsystems</h3>
            <p>Break down your robot's mechanisms with clear diagrams and explanations.</p>
          </div>
          <i class="fa-solid fa-chevron-right card-arrow"></i>
        </a>
        <a href="/lessons/lesson-7/" class="lesson-card">
          <div class="lesson-icon"><i class="fa-solid fa-code"></i></div>
          <div class="lesson-body">
            <h3>Software & Programming</h3>
            <p>Document your code architecture, autonomous routines, and driver controls.</p>
          </div>
          <i class="fa-solid fa-chevron-right card-arrow"></i>
        </a>
        <a href="/lessons/lesson-8/" class="lesson-card">
          <div class="lesson-icon"><i class="fa-solid fa-handshake"></i></div>
          <div class="lesson-body">
            <h3>Business & Community Impact</h3>
            <p>Showcase outreach, sponsorships, and your team's impact beyond the robot.</p>
          </div>
          <i class="fa-solid fa-chevron-right card-arrow"></i>
        </a>
        <a href="/lessons/lesson-9/" class="lesson-card">
          <div class="lesson-icon"><i class="fa-solid fa-bolt"></i></div>
          <div class="lesson-body">
            <h3>Spotlight Pages</h3>
            <p>Dedicate a page to something cool about your team and make it stand out.</p>
          </div>
          <i class="fa-solid fa-chevron-right card-arrow"></i>
        </a>
      </div>
    </div>
  </div>

  <div class="start-cta">
    <a href="/lessons/lesson-0/" class="btn-start">
      Start from the beginning
      <i class="fa-solid fa-arrow-right"></i>
    </a>
  </div>
</Layout>

<style>
  /* ── Hero ───────────────────────────────────── */
  .lessons-hero {
    text-align: center;
    padding: 1.5rem 1rem 0.5rem;
    margin-bottom: 0.5rem;
  }

  .lessons-hero h1 {
    margin: 0 0 0.4rem;
    font-size: 1.8rem;
    color: var(--text-heading);
  }

  .hero-sub {
    max-width: 500px;
    margin: 0 auto;
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.55;
  }

  /* ── Lessons list ──────────────────────────── */
  .lessons-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin: 1.5rem 0;
  }

  /* ── Section group ─────────────────────────── */
  .section-group {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .section-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin: 0;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    border: none;
    padding: 0 0 0 0.2rem;
  }

  .section-label i {
    font-size: 0.72rem;
    color: var(--accent);
  }

  /* ── Lesson cards ──────────────────────────── */
  .section-lessons {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .lesson-card {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.85rem 1.1rem;
    background: var(--bg-surface-solid);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
  }

  .lesson-card:hover {
    border-color: var(--border-accent);
    background: var(--bg-surface-hover);
    transform: translateX(3px);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
  }

  .lesson-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--accent-faint);
    color: var(--accent);
    font-size: 0.85rem;
    border-radius: 8px;
    flex-shrink: 0;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .lesson-card:hover .lesson-icon {
    background: var(--accent);
    color: #fff;
  }

  .lesson-body {
    flex: 1;
    min-width: 0;
  }

  .lesson-body h3 {
    margin: 0;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--text-heading);
    line-height: 1.3;
  }

  .lesson-body p {
    margin: 0.15rem 0 0;
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.4;
  }

  .card-arrow {
    color: var(--border);
    font-size: 0.7rem;
    flex-shrink: 0;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .lesson-card:hover .card-arrow {
    color: var(--accent);
    transform: translateX(3px);
  }

  /* ── CTA ────────────────────────────────────── */
  .start-cta {
    text-align: center;
    margin-top: 2rem;
    padding-bottom: 0.5rem;
  }

  .btn-start {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.4rem;
    background: var(--accent);
    color: #fff;
    font-weight: 600;
    font-size: 0.88rem;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background 0.2s ease, transform 0.15s ease, box-shadow 0.2s ease;
  }

  .btn-start:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(109, 40, 217, 0.3);
    text-decoration: none;
    color: #fff;
  }

  .btn-start i {
    font-size: 0.78rem;
    transition: transform 0.2s ease;
  }

  .btn-start:hover i {
    transform: translateX(3px);
  }

  /* ── Responsive ────────────────────────────── */
  @media (max-width: 640px) {
    .lessons-hero h1 {
      font-size: 1.45rem;
    }

    .hero-sub {
      font-size: 0.84rem;
    }

    .lesson-card {
      padding: 0.75rem 0.9rem;
    }

    .lesson-icon {
      width: 32px;
      height: 32px;
      font-size: 0.78rem;
    }

    .lesson-body p {
      display: none;
    }
  }
</style>
