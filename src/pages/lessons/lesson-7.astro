---
import Layout from '../../layouts/Layout.astro';
import LessonNav from '../../components/LessonNav.astro';
import LessonAudio from '../../components/LessonAudio.astro';
---
<Layout title="Lesson 8: Software & Programming">
  <div class="lesson-header">
    <span class="lesson-badge">Lesson 8</span>
    <h1>Software & Programming</h1>
    <p class="lesson-subtitle">How to show off your team's software work in your portfolio.</p>
    <LessonAudio slug="lesson-7" />
  </div>

  <p>
    Your software work deserves just as much attention as your mechanical design. Here's how to present it well in your portfolio.
  </p>

  <!-- Why Software Matters -->
  <div class="why-card">
    <div class="why-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
    </div>
    <div>
      <h2 style="margin-top:0;">Why Software Matters</h2>
      <p style="margin-bottom:0;">
        A lot of teams put all their focus on the mechanical side but don't realize how much judges care about software.
        Your code shows <strong>problem-solving</strong>, <strong>optimization</strong>, and <strong>engineering thinking</strong> - all things judges look for.
      </p>
    </div>
  </div>

  <!-- What to Include -->
  <h2>What to Include</h2>
  <div class="software-grid">
    <div class="sw-card">
      <span class="sw-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
      </span>
      <strong>Software Architecture</strong>
      <span class="sw-desc">How is your code organized? What design patterns do you use?</span>
    </div>
    <div class="sw-card">
      <span class="sw-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      </span>
      <strong>Key Algorithms</strong>
      <span class="sw-desc">Autonomous routines, control systems, vision processing, etc.</span>
    </div>
    <div class="sw-card">
      <span class="sw-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      </span>
      <strong>Unique Implementations</strong>
      <span class="sw-desc">What makes your code different or better than standard approaches?</span>
    </div>
    <div class="sw-card">
      <span class="sw-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/></svg>
      </span>
      <strong>Path Planning</strong>
      <span class="sw-desc">Libraries or custom code used for auto path planning.</span>
    </div>
    <div class="sw-card">
      <span class="sw-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      </span>
      <strong>Performance Improvements</strong>
      <span class="sw-desc">How your software evolved and improved throughout the season.</span>
    </div>
    <div class="sw-card">
      <span class="sw-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
      </span>
      <strong>Challenges Overcome</strong>
      <span class="sw-desc">Technical problems and the creative solutions you found.</span>
    </div>
  </div>

  <h3>Example: Software Architecture Diagram</h3>
  <p>You can also summarize your software structure visually:</p>
  <div class="arch-diagram">
    <div class="arch-layer">
      <span class="arch-label">Driver Input</span>
      <div class="arch-boxes">
        <span class="arch-box">Gamepad 1</span>
        <span class="arch-box">Gamepad 2</span>
      </div>
    </div>
    <div class="arch-arrow">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
    </div>
    <div class="arch-layer">
      <span class="arch-label">Control Layer</span>
      <div class="arch-boxes">
        <span class="arch-box accent">Drive Controller</span>
        <span class="arch-box accent">Arm Controller</span>
        <span class="arch-box accent">Vision Pipeline</span>
      </div>
    </div>
    <div class="arch-arrow">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><polyline points="19 12 12 19 5 12"/></svg>
    </div>
    <div class="arch-layer">
      <span class="arch-label">Hardware</span>
      <div class="arch-boxes">
        <span class="arch-box">Motors</span>
        <span class="arch-box">Servos</span>
        <span class="arch-box">Sensors</span>
        <span class="arch-box">Camera</span>
      </div>
    </div>
  </div>

  <!-- How to Present Code -->
  <h2>How to Present Code</h2>
  <p>
    Most judges won't understand your code, so focus on <strong>explaining the concepts</strong> rather than the syntax:
  </p>
  <div class="present-grid">
    <div class="present-card">
      <span class="present-num">1</span>
      <div>
        <strong>Use Diagrams</strong>
        <span class="present-desc">Diagrams showing how your autonomous routine works</span>
      </div>
    </div>
    <div class="present-card">
      <span class="present-num">2</span>
      <div>
        <strong>Provide Context</strong>
        <span class="present-desc">Explain why you chose each approach and what problem it solves</span>
      </div>
    </div>
    <div class="present-card">
      <span class="present-num">3</span>
      <div>
        <strong>Show Results</strong>
        <span class="present-desc">How much faster? More accurate? More reliable?</span>
      </div>
    </div>
    <div class="present-card">
      <span class="present-num">4</span>
      <div>
        <strong>Keep It Simple</strong>
        <span class="present-desc">Don't overwhelm with technical terms. Keep it clear.</span>
      </div>
    </div>
  </div>

  <!-- Allocation Guidelines -->
  <h2>Allocation Guidelines</h2>
  <div class="alloc-card">
    <div class="alloc-header">
      <span class="alloc-label">Software typically occupies</span>
      <span class="alloc-badge">1-2 pages</span>
    </div>
    <p style="margin:.5rem 0 .75rem;">The exact amount depends on:</p>
    <div class="alloc-factors">
      <div class="alloc-factor">
        <span class="factor-dot"></span>
        How software-focused your strategy is
      </div>
      <div class="alloc-factor">
        <span class="factor-dot"></span>
        The complexity of your autonomous routines
      </div>
      <div class="alloc-factor">
        <span class="factor-dot"></span>
        How much software improved your season performance
      </div>
      <div class="alloc-factor">
        <span class="factor-dot"></span>
        Space available after covering mechanical systems
      </div>
    </div>
  </div>

  <div class="callout note">
    <strong><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: inline-block; vertical-align: -0.15em; margin-right: 0.25em;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>Remember:</strong> If your team's strength is software, you can allocate more space. If mechanical is your focus, 1 page is sufficient.
    The portfolio should reflect your team's priorities.
  </div>

  <LessonNav 
    prev={{ title: "Robot Subsystems & Technical Pages", href: "/lessons/lesson-6/" }}
    next={{ title: "Business & Community Impact", href: "/lessons/lesson-8/" }}
  />
</Layout>

<style>
  /* Why Software Card */
  .why-card {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    background: var(--bg-surface-solid);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    margin: 1.5rem 0;
    transition: border-color .2s, box-shadow .2s;
  }
  .why-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
  }
  .why-icon {
    flex-shrink: 0;
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-faint);
    border-radius: var(--radius-sm);
    color: var(--accent);
  }

  /* Software Grid */
  .software-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
    margin: 1rem 0 2rem;
  }
  .sw-card {
    display: flex;
    flex-direction: column;
    gap: .5rem;
    background: var(--bg-surface-solid);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.25rem;
    transition: border-color .2s, box-shadow .2s, transform .2s;
  }
  .sw-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .sw-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-faint);
    border-radius: var(--radius-sm);
    color: var(--accent);
    flex-shrink: 0;
  }
  .sw-desc {
    font-size: .92rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* Present Grid */
  .present-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
    margin: 1rem 0 2rem;
  }
  .present-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: var(--bg-surface-solid);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.15rem 1.25rem;
    transition: border-color .2s, box-shadow .2s, transform .2s;
  }
  .present-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }
  .present-num {
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent);
    color: #fff;
    border-radius: 50%;
    font-weight: 700;
    font-size: .95rem;
  }
  .present-card div {
    display: flex;
    flex-direction: column;
    gap: .25rem;
  }
  .present-desc {
    font-size: .9rem;
    color: var(--text-muted);
    line-height: 1.45;
  }

  /* Allocation Card */
  .alloc-card {
    background: var(--bg-surface-solid);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    margin: 1rem 0 2rem;
    transition: border-color .2s, box-shadow .2s;
  }
  .alloc-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
  }
  .alloc-header {
    display: flex;
    align-items: center;
    gap: .75rem;
    flex-wrap: wrap;
  }
  .alloc-label {
    font-weight: 600;
    font-size: 1.05rem;
  }
  .alloc-badge {
    display: inline-flex;
    align-items: center;
    background: var(--accent);
    color: #fff;
    padding: .25rem .85rem;
    border-radius: 999px;
    font-weight: 700;
    font-size: .92rem;
  }
  .alloc-factors {
    display: flex;
    flex-direction: column;
    gap: .6rem;
  }
  .alloc-factor {
    display: flex;
    align-items: center;
    gap: .65rem;
    font-size: .93rem;
    color: var(--text-muted);
  }
  .factor-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  /* Responsive */
  @media (max-width: 600px) {
    .why-card { flex-direction: column; }
    .software-grid,
    .present-grid { grid-template-columns: 1fr; }
    .arch-boxes { flex-direction: column; }
  }

  /* Architecture Diagram */
  .arch-diagram {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .5rem;
    padding: 1.5rem;
    background: var(--bg-surface-solid);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    margin: 1rem 0 2rem;
  }
  .arch-layer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: .5rem;
    width: 100%;
  }
  .arch-label {
    font-size: .75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .04em;
    color: var(--text-muted);
  }
  .arch-boxes {
    display: flex;
    gap: .5rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .arch-box {
    padding: .45rem .85rem;
    background: var(--bg-surface-hover);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: .8rem;
    font-weight: 500;
    color: var(--text-secondary);
  }
  .arch-box.accent {
    background: var(--accent-faint);
    border-color: var(--border-accent);
    color: var(--accent);
    font-weight: 600;
  }
  .arch-arrow {
    color: var(--text-muted);
    display: flex;
    align-items: center;
  }
</style>


