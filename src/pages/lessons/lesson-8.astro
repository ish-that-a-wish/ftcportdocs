---
import Layout from '../../layouts/Layout.astro';
import LessonNav from '../../components/LessonNav.astro';
import LessonAudio from '../../components/LessonAudio.astro';
---
<Layout title="Lesson 9: Business & Community Impact">
  <div class="lesson-header">
    <span class="lesson-badge">Lesson 9</span>
    <h1>Business & Community Impact</h1>
    <p class="lesson-subtitle">How to present your team's finances, sustainability, and community work.</p>
    <LessonAudio slug="lesson-8" />
  </div>

  <p>
    This part of the portfolio covers how you manage your team's money, keep things running long-term, and give back to your community.
    It breaks down into <strong>two main areas</strong> that judges look at:
  </p>

  <!-- ── Two Pillars ────────────────────────── -->
  <div class="pillar-grid">
    <div class="pillar-card">
      <div class="pillar-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
      </div>
      <h2>Finances &amp; Sustainability</h2>
      <p class="pillar-desc">Judges want to see that your team handles money well and has a plan to keep going year after year.</p>
      <div class="topic-list">
        <div class="topic-item">
          <span class="topic-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>
          </span>
          <div>
            <strong>Budget Management</strong>
            <p>How much did you spend? Where did the money come from?</p>
          </div>
        </div>
        <div class="topic-item">
          <span class="topic-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </span>
          <div>
            <strong>Cost Justification</strong>
            <p>Why did you choose certain components or materials?</p>
          </div>
        </div>
        <div class="topic-item">
          <span class="topic-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
          </span>
          <div>
            <strong>Fundraising Strategy</strong>
            <p>How does your team fund operations year after year?</p>
          </div>
        </div>
        <div class="topic-item">
          <span class="topic-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </span>
          <div>
            <strong>Member Development</strong>
            <p>How do you train new members and develop skills?</p>
          </div>
        </div>
        <div class="topic-item">
          <span class="topic-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
          </span>
          <div>
            <strong>Succession Planning</strong>
            <p>How does your team maintain continuity as members graduate?</p>
          </div>
        </div>
        <div class="topic-item">
          <span class="topic-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
          </span>
          <div>
            <strong>Sponsorship Relationships</strong>
            <p>How do you partner with local businesses?</p>
          </div>
        </div>
      </div>
    </div>

    <div class="pillar-card">
      <div class="pillar-icon community">
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </div>
      <h2>Community Impact</h2>
      <p class="pillar-desc">Show how your team gives back to the community and promotes STEM.</p>
      <div class="topic-list">
        <div class="topic-item">
          <span class="topic-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </span>
          <div>
            <strong>Outreach Events</strong>
            <p>Demo days, STEM camps, school visits</p>
          </div>
        </div>
        <div class="topic-item">
          <span class="topic-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </span>
          <div>
            <strong>Mentorship Programs</strong>
            <p>How you help younger or newer teams</p>
          </div>
        </div>
        <div class="topic-item">
          <span class="topic-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </span>
          <div>
            <strong>STEM Promotion</strong>
            <p>Efforts to inspire students in science and engineering</p>
          </div>
        </div>
        <div class="topic-item">
          <span class="topic-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10A15.3 15.3 0 0 1 12 2z"/></svg>
          </span>
          <div>
            <strong>Local Partnerships</strong>
            <p>Collaborations with schools, libraries, or organizations</p>
          </div>
        </div>
        <div class="topic-item">
          <span class="topic-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </span>
          <div>
            <strong>Volunteer Work</strong>
            <p>Community service and volunteer hours</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── Allocation Guidelines ──────────────── -->
  <h2>Allocation Guidelines</h2>
  <p>
    Combined, these topics usually take up <strong>1-3 pages</strong> depending on your team's strengths. Here's how different team types might split their space:
  </p>

  <div class="allocation-bars">
    <div class="alloc-row">
      <span class="alloc-label">Business-focused</span>
      <div class="alloc-track">
        <div class="alloc-fill finance" style="width: 65%;">Finances</div>
        <div class="alloc-fill community" style="width: 35%;">Community</div>
      </div>
    </div>
    <div class="alloc-row">
      <span class="alloc-label">Outreach-focused</span>
      <div class="alloc-track">
        <div class="alloc-fill finance" style="width: 30%;">Finances</div>
        <div class="alloc-fill community" style="width: 70%;">Community</div>
      </div>
    </div>
    <div class="alloc-row">
      <span class="alloc-label">Balanced</span>
      <div class="alloc-track">
        <div class="alloc-fill finance" style="width: 50%;">Finances</div>
        <div class="alloc-fill community" style="width: 50%;">Community</div>
      </div>
    </div>
  </div>

  <!-- ── How to Stand Out ──────────── -->
  <h2>How to Stand Out</h2>
  <p>Don't just list bullet points. Show judges the real difference you made:</p>

  <div class="tips-grid">
    <div class="tip-card">
      <div class="tip-num">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
      </div>
      <div>
        <strong>Use numbers</strong>
        <p>"We raised $15,000" or "Reached 200 students this year"</p>
      </div>
    </div>
    <div class="tip-card">
      <div class="tip-num">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      </div>
      <div>
        <strong>Show photos</strong>
        <p>Outreach events, team members in action, community moments</p>
      </div>
    </div>
    <div class="tip-card">
      <div class="tip-num">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
      </div>
      <div>
        <strong>Tell stories</strong>
        <p>Real examples of how you helped someone or grew as a team</p>
      </div>
    </div>
    <div class="tip-card">
      <div class="tip-num">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
      </div>
      <div>
        <strong>Demonstrate impact</strong>
        <p>Did you inspire students to join FIRST? Strengthen your community?</p>
      </div>
    </div>
    <div class="tip-card">
      <div class="tip-num">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </div>
      <div>
        <strong>Be authentic</strong>
        <p>Judges can tell when stories are real. Don't overthink it - sincerity goes further than polish.</p>
      </div>
    </div>
  </div>

  <!-- Sample Impact Page Layout -->
  <h2>Sample Impact Page</h2>
  <p>Here's how to lay out your business and community information effectively:</p>

  <div class="impact-layout-example">
    <div class="impact-sample-page">
      <div class="impact-page-header">Community Impact</div>
      <div class="impact-page-body">
        <div class="impact-stats-row">
          <div class="impact-stat">
            <span class="impact-stat-num">200+</span>
            <span class="impact-stat-label">Students Reached</span>
          </div>
          <div class="impact-stat">
            <span class="impact-stat-num">12</span>
            <span class="impact-stat-label">Events Hosted</span>
          </div>
          <div class="impact-stat">
            <span class="impact-stat-num">$15k</span>
            <span class="impact-stat-label">Funds Raised</span>
          </div>
        </div>
        <div class="impact-photo-row">
          <div class="impact-photo-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="impact-photo-icon"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
          <div class="impact-photo-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="impact-photo-icon"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
          <div class="impact-photo-box">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="impact-photo-icon"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
        </div>
        <div class="impact-text-block">
          <div class="impact-text-line"></div>
          <div class="impact-text-line" style="width:90%;"></div>
          <div class="impact-text-line" style="width:75%;"></div>
        </div>
      </div>
    </div>
    <div class="impact-layout-notes">
      <div class="impact-layout-note">
        <span class="impact-layout-dot"></span>
        Lead with numbers to show measurable impact
      </div>
      <div class="impact-layout-note">
        <span class="impact-layout-dot"></span>
        Photos from events make outreach tangible
      </div>
      <div class="impact-layout-note">
        <span class="impact-layout-dot"></span>
        Brief text tells the story behind the numbers
      </div>
    </div>
  </div>

  <div class="callout tip">
    <strong><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: inline-block; vertical-align: -0.15em; margin-right: 0.25em;"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"></path><path d="M9 18h6"></path><path d="M10 22h4"></path></svg>Pro Tip:</strong> Judges appreciate teams that balance competitive robotics with community responsibility.
    Even if your outreach is small, showing consistent effort matters.
  </div>

  <LessonNav 
    prev={{ title: "Software & Programming", href: "/lessons/lesson-7/" }}
    next={{ title: "Spotlight Pages", href: "/lessons/lesson-9/" }}
  />
</Layout>

<style>
  /* ── Pillar grid ───────────────────────────── */
  .pillar-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin: 1.5rem 0 2.5rem;
  }

  .pillar-card {
    padding: 1.75rem;
    background: var(--bg-surface-solid);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }

  .pillar-card:hover {
    border-color: var(--border-accent);
    box-shadow: var(--shadow-md);
  }

  .pillar-card h2 {
    margin: 0.75rem 0 0.35rem;
    font-size: 1.25rem;
    border: none;
    padding: 0;
  }

  .pillar-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 14px;
    background: var(--accent-faint);
    color: var(--accent);
  }

  .pillar-icon.community {
    background: rgba(236, 72, 153, 0.08);
    color: #ec4899;
  }

  [data-theme="dark"] .pillar-icon.community {
    background: rgba(236, 72, 153, 0.15);
    color: #f472b6;
  }

  .pillar-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  /* ── Topic items ───────────────────────────── */
  .topic-list {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.65rem;
  }

  .topic-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 0.85rem;
    background: var(--bg-surface-hover);
    border-radius: var(--radius-sm);
    transition: background 0.15s ease;
  }

  .topic-item:hover {
    background: var(--accent-faint);
  }

  .topic-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: var(--accent-faint);
    color: var(--accent);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .pillar-card:nth-child(2) .topic-icon {
    background: rgba(236, 72, 153, 0.08);
    color: #ec4899;
  }

  [data-theme="dark"] .pillar-card:nth-child(2) .topic-icon {
    background: rgba(236, 72, 153, 0.15);
    color: #f472b6;
  }

  .topic-item strong {
    display: block;
    font-size: 0.9rem;
    color: var(--text-heading);
    margin-bottom: 0.1rem;
  }

  .topic-item p {
    margin: 0;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  /* ── Allocation bars ───────────────────────── */
  .allocation-bars {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 1.25rem 0 2rem;
    padding: 1.5rem;
    background: var(--bg-surface-solid);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .alloc-row {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .alloc-label {
    width: 130px;
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text-secondary);
    flex-shrink: 0;
    text-align: right;
  }

  .alloc-track {
    flex: 1;
    display: flex;
    height: 32px;
    border-radius: var(--radius-sm);
    overflow: hidden;
    border: 1px solid var(--border);
  }

  .alloc-fill {
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.72rem;
    font-weight: 600;
    color: #fff;
    transition: width 0.6s ease;
  }

  .alloc-fill.finance {
    background: var(--accent);
  }

  .alloc-fill.community {
    background: #ec4899;
  }

  [data-theme="dark"] .alloc-fill.community {
    background: #db2777;
  }

  /* ── Tips grid ─────────────────────────────── */
  .tips-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 0.85rem;
    margin: 1.25rem 0 1.5rem;
  }

  .tip-card {
    display: flex;
    align-items: flex-start;
    gap: 0.85rem;
    padding: 1rem 1.15rem;
    background: var(--bg-surface-solid);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .tip-card:hover {
    border-color: var(--border-accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .tip-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    background: var(--accent-faint);
    color: var(--accent);
    flex-shrink: 0;
  }

  .tip-card strong {
    display: block;
    font-size: 0.9rem;
    color: var(--text-heading);
    margin-bottom: 0.2rem;
  }

  .tip-card > div p {
    margin: 0;
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* ── Responsive ────────────────────────────── */
  @media (max-width: 768px) {
    .topic-list {
      grid-template-columns: 1fr;
    }

    .alloc-label {
      width: 100px;
      font-size: 0.75rem;
    }

    .alloc-fill {
      font-size: 0.65rem;
    }

    .tips-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .alloc-row {
      flex-direction: column;
      align-items: stretch;
    }

    .alloc-label {
      width: auto;
      text-align: left;
    }
  }

  /* Impact page layout example */
  .impact-layout-example {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 1.5rem;
    align-items: start;
    margin: 1.25rem 0 1.5rem;
  }

  .impact-sample-page {
    background: var(--bg-surface-solid);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    aspect-ratio: 8.5 / 11;
  }

  .impact-page-header {
    background: var(--accent);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.4rem 0.75rem;
    text-align: center;
  }

  .impact-page-body {
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .impact-stats-row {
    display: flex;
    justify-content: space-around;
    gap: 0.35rem;
  }

  .impact-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.1rem;
  }

  .impact-stat-num {
    font-size: 0.85rem;
    font-weight: 800;
    color: var(--accent);
  }

  .impact-stat-label {
    font-size: 0.48rem;
    color: var(--text-muted);
    text-align: center;
  }

  .impact-photo-row {
    display: grid;
