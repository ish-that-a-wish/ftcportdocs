---
import Layout from '../../layouts/Layout.astro';
import LessonNav from '../../components/LessonNav.astro';
import LessonAudio from '../../components/LessonAudio.astro';
---
<Layout title="Lesson 4: Team Overview">
  <div class="lesson-header">
    <span class="lesson-badge">Lesson 4</span>
    <h1>Team Overview</h1>
    <p class="lesson-subtitle">Kick off your portfolio with a strong intro to your team and season.</p>
    <LessonAudio slug="lesson-4" />
  </div>

  <p>
    This is usually the first section of your portfolio, and it's where you hook the judges. Give them a quick, high-level look at your season that makes them want to keep reading.
  </p>

  <h2>What to Include</h2>

  <div class="overview-grid">
    <div class="ov-card">
      <div class="ov-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
      </div>
      <div>
        <strong>Awards &amp; Recognitions</strong>
        <p>Showcase any awards or special recognitions your team received this season.</p>
      </div>
    </div>
    <div class="ov-card">
      <div class="ov-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
      </div>
      <div>
        <strong>Impact &amp; Growth</strong>
        <p>Describe how your team grew and the impact you had on your community.</p>
      </div>
    </div>
    <div class="ov-card">
      <div class="ov-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
      </div>
      <div>
        <strong>Team Roles</strong>
        <p>Describe the roles and responsibilities of each team member.</p>
      </div>
    </div>
  </div>

  <h2>Make It Memorable</h2>
  <p>You should also include your team mission, values, and whatever makes your team unique. Here are some ways to stand out:</p>

  <div class="tips-row">
    <div class="mini-tip">
      <span class="mini-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      </span>
      <div>
        <strong>Team Mission Statement</strong>
        <p>What drives your team? Why do you compete?</p>
      </div>
    </div>
    <div class="mini-tip">
      <span class="mini-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      </span>
      <div>
        <strong>Team Photos</strong>
        <p>Include a team photo and action shots at events.</p>
      </div>
    </div>
    <div class="mini-tip">
      <span class="mini-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
      </span>
      <div>
        <strong>Unique Culture</strong>
        <p>What traditions, values, or fun facts set your team apart?</p>
      </div>
    </div>
    <div class="mini-tip">
      <span class="mini-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      </span>
      <div>
        <strong>Season Highlights</strong>
        <p>Preview the key moments judges will read about.</p>
      </div>
    </div>
  </div>

  <!-- Sample Team Overview Layout -->
  <h2>Sample Team Overview Layout</h2>
  <p>Here's what a solid team overview page could look like:</p>

  <div class="team-layout-example">
    <div class="team-sample-page">
      <div class="team-sample-header">Team Overview</div>
      <div class="team-sample-body">
        <div class="team-sample-photo">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="team-photo-icon"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <span class="team-photo-label">Team Photo</span>
        </div>
        <div class="team-sample-section">
          <div class="team-sample-label">Mission Statement</div>
          <div class="team-sample-line"></div>
          <div class="team-sample-line" style="width:80%;"></div>
        </div>
        <div class="team-sample-section">
          <div class="team-sample-label">Team Roles</div>
          <div class="team-role-grid">
            <div class="team-role-box"><span>Lead</span></div>
            <div class="team-role-box"><span>Build</span></div>
            <div class="team-role-box"><span>Code</span></div>
            <div class="team-role-box"><span>Docs</span></div>
          </div>
        </div>
        <div class="team-sample-section">
          <div class="team-sample-label">Season Highlights</div>
          <div class="team-hl-row">
            <div class="team-hl-icon"></div>
            <div class="team-sample-line"></div>
          </div>
          <div class="team-hl-row">
            <div class="team-hl-icon"></div>
            <div class="team-sample-line" style="width:75%;"></div>
          </div>
        </div>
      </div>
    </div>
    <div class="team-layout-notes">
      <div class="team-layout-note">
        <span class="team-layout-dot"></span>
        Large team photo creates a personal connection with judges
      </div>
      <div class="team-layout-note">
        <span class="team-layout-dot"></span>
        Mission statement shows your team's purpose and values
      </div>
      <div class="team-layout-note">
        <span class="team-layout-dot"></span>
        Role grid gives judges a quick view of team structure
      </div>
      <div class="team-layout-note">
        <span class="team-layout-dot"></span>
        Season highlights hook judges to keep reading
      </div>
    </div>
  </div>

  <div class="callout tip">
    <strong><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display: inline-block; vertical-align: -0.15em; margin-right: 0.25em;"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"></path><path d="M9 18h6"></path><path d="M10 22h4"></path></svg>Pro Tip:</strong> Think of your Team Overview as a preview. Give judges a clear summary that makes them want to read the whole portfolio.
  </div>

  <LessonNav 
    prev={{ title: "Best Practices", href: "/lessons/lesson-2/" }}
    next={{ title: "Design Process", href: "/lessons/lesson-3/" }}
  />
</Layout>

<style>
  .overview-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.85rem;
    margin: 1.25rem 0 1.5rem;
  }

  .ov-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
    background: var(--bg-surface-solid);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .ov-card:hover {
    border-color: var(--border-accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .ov-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--accent-faint);
    color: var(--accent);
  }

  .ov-card strong {
    display: block;
    font-size: 0.95rem;
    color: var(--text-heading);
    margin-bottom: 0.15rem;
  }

  .ov-card > div p {
    margin: 0;
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .tips-row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.65rem;
    margin: 1.25rem 0 1.5rem;
  }

  .mini-tip {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    background: var(--bg-surface-hover);
    border-radius: var(--radius-sm);
    transition: background 0.15s ease;
  }

  .mini-tip:hover {
    background: var(--accent-faint);
  }

  .mini-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: var(--accent-faint);
    color: var(--accent);
    flex-shrink: 0;
  }

  .mini-tip strong {
    display: block;
    font-size: 0.88rem;
    color: var(--text-heading);
    margin-bottom: 0.1rem;
  }

  .mini-tip p {
    margin: 0;
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  @media (max-width: 768px) {
    .overview-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .tips-row {
      grid-template-columns: 1fr;
    }
    .team-layout-example {
      grid-template-columns: 1fr;
    }
    .team-sample-page {
      aspect-ratio: auto;
    }
  }

  /* Team overview layout example */
  .team-layout-example {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 1.5rem;
    align-items: start;
    margin: 1.25rem 0 1.5rem;
  }

  .team-sample-page {
    background: var(--bg-surface-solid);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    aspect-ratio: 8.5 / 11;
  }

  .team-sample-header {
    background: var(--accent);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.4rem 0.75rem;
    text-align: center;
  }

  .team-sample-body {
    padding: 0.65rem;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }

  .team-sample-photo {
    width: 100%;
    height: 70px;
    background: var(--accent-faint);
    border-radius: var(--radius-sm);
    border: 1.5px dashed var(--border-accent);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.2rem;
  }

  .team-photo-icon {
    color: var(--accent);
    opacity: 0.5;
  }

  .team-photo-label {
    font-size: 0.5rem;
    font-weight: 600;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .team-sample-section {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .team-sample-label {
    font-size: 0.55rem;
    font-weight: 700;
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .team-sample-line {
    height: 5px;
    background: var(--bg-surface-hover);
    border-radius: 3px;
    width: 100%;
  }

  .team-role-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.25rem;
  }

  .team-role-box {
    height: 22px;
    background: var(--bg-surface-hover);
    border-radius: 4px;
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .team-role-box span {
    font-size: 0.45rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .team-hl-row {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .team-hl-icon {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
    opacity: 0.6;
  }

  .team-layout-notes {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    padding-top: 0.25rem;
  }

  .team-layout-note {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .team-layout-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }
</style>

