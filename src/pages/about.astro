---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About: EP Docs">
  <div class="about-hero">
    <div class="hero-gradient"></div>
    <h1 class="fade-in">About This Project</h1>
    <p class="subtitle fade-in" style="--delay: 0.15s">Helping FTC teams build better portfolios.</p>
  </div>

  <div class="about-content">
    <!-- Main intro section with image -->
    <div class="intro-section">
      <div class="intro-text">
          <h2 class="slide-in">The Mission</h2>
        <p class="slide-in" style="--delay: 0.1s">
          This website was created in January 2026 as a resource for FTC teams working on their Engineering Portfolio. Code, build, CAD, and other FTC skills are all documented online. There's courses, open-source explanations, and videos to follow along. Meanwhile, there's little to nothing about the EP. The best way to learn is by observing other portfolios, but another great way is to have some documentation on what some good practices are for design. The goal was for this website to be that documentation.
        </p>
        <p class="slide-in" style="--delay: 0.2s">
          Whether you're a rookie team making your first portfolio or a veteran team trying to take yours to the next level, you'll find examples, resources, and tips that actually help.
        </p>
      </div>
    </div>

    <!-- Contributors -->
    <div class="contributors-section">
      <h2 class="section-title">Contributors</h2>
      <div class="contributors-grid">
        <div class="contributor-card" style="--i: 0">
          <div class="contributor-avatar">
            <i class="fa-solid fa-crown"></i>
          </div>
          <div class="contributor-info">
            <span class="contributor-name">Ishika S</span>
            <span class="contributor-role">Creator & Lead Developer</span>
            <span class="contributor-team">FTC 26336</span>
          </div>
        </div>
      </div>
      <div class="contributor-cta">
        <p>Want to contribute to this project?</p>
        <a href="https://docs.google.com/forms/d/e/1FAIpQLSd1OdPIsOgO6vRMzhizG8CTM6tqowzYoKg5dYNNfYzpBihdCw/viewform?usp=publish-editor" target="_blank" rel="noopener" class="cta-button">
          <i class="fa-solid fa-paper-plane"></i>
          Apply to be a Contributor
        </a>
      </div>
    </div>

    <!-- Coming Soon / Contribute -->
    <div class="coming-soon-section">
      <h2 class="section-title">Want to Contribute?</h2>
      <p class="cs-subtitle">This project is open-source and welcomes contributions from the FTC community!</p>
      
      <div class="cs-hero-card">
        <div class="cs-glow"></div>
        <div class="cs-hero-inner">
          <div class="cs-badge-row">
            <span class="cs-badge">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              Open Source
            </span>
          </div>
          <h3>Help Shape the Future of EP Docs</h3>
          <p>Whether you want to add new lessons, improve existing content, fix bugs, or suggest features - any contribution helps FTC teams build better portfolios.</p>
        </div>
      </div>

      <div class="cs-timeline">
        <div class="cs-step">
          <div class="cs-step-line">
            <span class="cs-dot">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            </span>
            <div class="cs-connector"></div>
          </div>
          <div class="cs-step-content">
            <strong>Fork the Repository</strong>
            <p>Start by forking the <a href="https://github.com/ish-that-a-wish/ftcportdocs" target="_blank" rel="noopener">EP Docs repo on GitHub</a></p>
          </div>
        </div>
        <div class="cs-step">
          <div class="cs-step-line">
            <span class="cs-dot">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
            </span>
            <div class="cs-connector"></div>
          </div>
          <div class="cs-step-content">
            <strong>Create a New Lesson or Fix</strong>
            <p>Make your changes locally: new lessons, content improvements, or bug fixes.</p>
          </div>
        </div>
        <div class="cs-step">
          <div class="cs-step-line">
            <span class="cs-dot">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </span>
            <div class="cs-connector"></div>
          </div>
          <div class="cs-step-content">
            <strong>Submit a Pull Request</strong>
            <p>Open a PR with a clear description. We will review and provide feedback.</p>
          </div>
        </div>
        <div class="cs-step">
          <div class="cs-step-line">
            <span class="cs-dot final">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
          </div>
          <div class="cs-step-content">
            <strong>Get Approved &amp; Merged</strong>
            <p>Your contribution goes live within 24-48 hours.</p>
          </div>
        </div>
      </div>

      <div class="cs-cta-area">
        <div class="cs-impact-note">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          Even a typo fix helps hundreds of FTC teams. We appreciate every contribution!
        </div>
        <a href="https://github.com/ish-that-a-wish/ftcportdocs" target="_blank" rel="noopener" class="contribute-button">
          <i class="fa-brands fa-github"></i>
          View on GitHub
        </a>
      </div>
    </div>

    <!-- Tech stack -->
    <div class="tech-section">
      <h2 class="section-title">Built with</h2>
      <div class="tech-stack">
        <div class="tech-item" style="--i: 0">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
          <span>Astro</span>
        </div>
        <div class="tech-item" style="--i: 1">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          <span>TypeScript</span>
        </div>
        <div class="tech-item" style="--i: 2">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          <span>CSS</span>
        </div>
        <div class ="tech-item" style="--i: 3">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2a10 10 0 1 0 10 10A10 10 0 0 0 12 2z"/><line x1="12" y1="6" x2="12" y2="12"/><line x1="12" y1="12" x2="16" y2="14"/></svg>
            <span>Starlight</span>
        </div>
        <div class="tech-item" style="--i: 4">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10A15.3 15.3 0 0 1 12 2z"/></svg>
          <span>Hosted on Netlify</span>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* ── Hero section ─────────────────────────── */
  .about-hero {
    position: relative;
    text-align: center;
    padding: 2.5rem 1rem 2rem;
    margin-bottom: 2rem;
    overflow: hidden;
  }

  .hero-gradient {
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle at 50% 50%, var(--accent-faint) 0%, transparent 50%);
    opacity: 0.6;
    animation: gradient-spin 20s linear infinite;
    pointer-events: none;
  }

  @keyframes gradient-spin {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
  }

  .about-hero h1 {
    position: relative;
    z-index: 2;
    margin: 0;
    font-size: 2.2rem;
    background: linear-gradient(135deg, var(--accent) 0%, var(--accent-hover) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .subtitle {
    position: relative;
    z-index: 2;
    margin-top: 0.5rem;
    font-size: 1rem;
    color: var(--text-muted);
  }

  .fade-in {
    opacity: 0;
    animation: fadeUp 0.8s ease forwards;
    animation-delay: var(--delay, 0s);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ── Main content ─────────────────────────── */
  .about-content {
    max-width: 100%;
  }

  .intro-section {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    align-items: start;
    margin-bottom: 3rem;
  }

  .intro-text h2 {
    margin-top: 0;
  }

  .intro-text p {
    line-height: 1.75;
  }

  .slide-in {
    opacity: 0;
    animation: slideInLeft 0.7s ease forwards;
    animation-delay: var(--delay, 0s);
  }

  @keyframes slideInLeft {
    from { opacity: 0; transform: translateX(-20px); }
    to   { opacity: 1; transform: translateX(0); }
  }

  /* ── Features grid ────────────────────────── */
  .section-title {
    font-size: 1.4rem;
    margin: 2.5rem 0 1.5rem;
    text-align: center;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.25rem;
    margin-bottom: 3rem;
  }

  .feature-card {
    padding: 1.5rem;
    background: var(--bg-surface-solid);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    opacity: 0;
    animation: popIn 0.6s ease forwards;
    animation-delay: calc(0.5s + var(--i) * 0.12s);
  }

  @keyframes popIn {
    from { opacity: 0; transform: scale(0.9) translateY(10px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }

  .feature-card:hover {
    transform: translateY(-5px) scale(1.02);
    border-color: var(--border-accent);
    box-shadow: var(--shadow-md);
  }

  .feature-icon {
    color: var(--accent);
    margin-bottom: 0.75rem;
    transition: transform 0.3s ease;
  }

  .feature-card:hover .feature-icon {
    transform: scale(1.1) rotate(5deg);
  }

  .feature-card h4 {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    color: var(--text-heading);
  }

  .feature-card p {
    margin: 0;
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* ── Contributors section ──────────────── */
  .contributors-section {
    margin-bottom: 2.5rem;
  }

  .contributors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .contributor-card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--bg-surface-solid);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
    opacity: 0;
    animation: popIn 0.6s ease forwards;
    animation-delay: calc(0.3s + var(--i, 0) * 0.1s);
  }

  .contributor-card:hover {
    border-color: var(--border-accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .contributor-avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: var(--accent-faint);
    color: var(--accent);
    border-radius: 12px;
    font-size: 1.1rem;
    flex-shrink: 0;
  }

  .contributor-info {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .contributor-name {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-heading);
  }

  .contributor-role {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  .contributor-team {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent);
  }

  .contributor-cta {
    text-align: center;
    padding: 1.5rem;
    background: var(--bg-surface-solid);
    border: 1px dashed var(--border-accent);
    border-radius: var(--radius-md);
  }

  .contributor-cta p {
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .cta-button {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.25rem;
    background: var(--accent);
    color: #fff;
    font-size: 0.85rem;
    font-weight: 600;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .cta-button:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
    color: #fff;
    text-decoration: none;
  }

  /* ── Tech section ─────────────────────────── */
  .tech-section {
    padding: 2rem;
    background: var(--bg-surface-solid);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    text-align: center;
  }

  .tech-section h2 {
    margin-top: 0;
  }

  .tech-stack {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .tech-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.1rem;
    background: var(--bg-surface-hover);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
    opacity: 0;
    animation: fadeUp 0.5s ease forwards;
    animation-delay: calc(1.2s + var(--i) * 0.1s);
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .tech-item:hover {
    transform: translateY(-2px);
    border-color: var(--border-accent);
  }

  .tech-item svg {
    color: var(--accent);
  }

  /* ── Coming Soon / Contribute Section ────── */
  .coming-soon-section {
    margin-bottom: 3rem;
  }

  .cs-subtitle {
    text-align: center;
    color: var(--text-muted);
    font-size: 0.95rem;
    margin-top: -0.75rem;
    margin-bottom: 1.75rem;
  }

  .cs-hero-card {
    position: relative;
    padding: 2rem 2.25rem;
    background: var(--bg-surface-solid);
    border: 1px solid var(--border-accent);
    border-radius: var(--radius-lg);
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .cs-glow {
    position: absolute;
    top: -40%;
    right: -20%;
    width: 60%;
    height: 180%;
    background: radial-gradient(ellipse at center, var(--accent-faint) 0%, transparent 70%);
    pointer-events: none;
    animation: cs-glow-pulse 4s ease-in-out infinite alternate;
  }

  @keyframes cs-glow-pulse {
    0%   { opacity: 0.4; transform: scale(1); }
    100% { opacity: 0.8; transform: scale(1.1); }
  }

  .cs-hero-inner {
    position: relative;
    z-index: 1;
  }

  .cs-badge-row {
    margin-bottom: 0.75rem;
  }

  .cs-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.8rem;
    background: var(--accent);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border-radius: var(--radius-sm);
  }

  .cs-hero-card h3 {
    margin: 0 0 0.5rem;
    font-size: 1.4rem;
    color: var(--text-heading);
  }

  .cs-hero-card p {
    margin: 0;
    font-size: 0.92rem;
    color: var(--text-secondary);
    line-height: 1.7;
    max-width: 560px;
  }

  /* ── Timeline ─────────────────────────────── */
  .cs-timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-bottom: 2rem;
  }

  .cs-step {
    display: flex;
    gap: 1rem;
    min-height: 70px;
  }

  .cs-step-line {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 40px;
    flex-shrink: 0;
  }

  .cs-dot {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--accent-faint);
    color: var(--accent);
    border: 2px solid var(--accent);
    flex-shrink: 0;
    z-index: 1;
  }

  .cs-dot.final {
    background: var(--accent);
    color: #fff;
  }

  .cs-connector {
    width: 2px;
    flex: 1;
    background: linear-gradient(to bottom, var(--accent), var(--border));
    margin: 4px 0;
  }

  .cs-step-content {
    padding: 0.5rem 0 1.5rem;
  }

  .cs-step-content strong {
    display: block;
    font-size: 0.95rem;
    color: var(--text-heading);
    margin-bottom: 0.2rem;
  }

  .cs-step-content p {
    margin: 0;
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.55;
  }

  .cs-step-content a {
    color: var(--accent);
    font-weight: 500;
  }

  /* ── CTA area ─────────────────────────────── */
  .cs-cta-area {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    background: var(--bg-surface-solid);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    flex-wrap: wrap;
  }

  .cs-impact-note {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.88rem;
    color: var(--text-secondary);
  }

  .cs-impact-note svg {
    color: #ec4899;
    flex-shrink: 0;
  }

  .contribute-button {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 1.5rem;
    background: var(--accent);
    color: #fff;
    font-weight: 600;
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .contribute-button:hover {
    background: var(--accent-hover);
    transform: translateY(-2px);
    color: #fff;
    text-decoration: none;
  }

  /* ── Responsive ───────────────────────────── */
  @media (max-width: 768px) {
    .intro-section {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .about-hero h1 {
      font-size: 1.8rem;
    }

    .features-grid {
      grid-template-columns: 1fr;
    }

    .tech-stack {
      gap: 0.75rem;
    }

    .cs-cta-area {
      flex-direction: column;
      text-align: center;
    }

    .cs-impact-note {
      justify-content: center;
    }
  }

  @media (max-width: 480px) {
    .about-hero h1 {
      font-size: 1.5rem;
    }

    .tech-section {
      padding: 1.5rem 1rem;
    }

    .cs-hero-card {
      padding: 1.5rem;
    }
  }
</style>